// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------
// ENUMS PARA INTEGRIDAD FINANCIERA Y FACTURACIÓN
// ----------------------------------------------------
enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionStatus {
  PENDING
  PAID
  CANCELLED
}

enum RecurrenceFrequency {
  MONTHLY
  ANNUAL
}

// NUEVO: Enum para el estado de las facturas (Borradores vs SAT)
enum InvoiceStatus {
  DRAFT // Borrador (No timbrada)
  TIMBRADA // Aprobada por el SAT
  CANCELLED // Cancelada en el SAT
}

// 👤 MÓDULO AUTH
model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// 📦 MÓDULO SERVICIOS Y CLIENTES
model Service {
  id           String                 @id @default(uuid())
  name         String                 @unique
  isActive     Boolean                @default(true)
  transactions FinancialTransaction[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
}

model Client {
  id                String                 @id @default(uuid())
  firstName         String
  lastName1         String
  lastName2         String?
  documentReminders DocumentReminder[]
  rfc               String                 @unique
  phone             String?
  email             String?
  isActive          Boolean                @default(true)
  transactions      FinancialTransaction[]
  subscriptions     Subscription[]
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
}

// ⏰ MÓDULO RECORDATORIOS
model DocumentReminder {
  id String @id @default(uuid())

  // Relación con el Cliente
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  documentType   String
  rfc            String?
  expirationDate DateTime
  notified7Days  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 🔄 MÓDULO SUSCRIPCIONES
model Subscription {
  id          String              @id @default(uuid())
  clientId    String
  client      Client              @relation(fields: [clientId], references: [id])
  serviceName String
  amount      Decimal             @db.Decimal(10, 2)
  frequency   RecurrenceFrequency
  startDate   DateTime
  nextBilling DateTime
  isActive    Boolean             @default(true)

  // 👇 NUEVO: Relación para que la suscripción sepa cuáles son sus recibos generados
  transactions FinancialTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 💰 MÓDULO FINANZAS
model FinancialTransaction {
  id          String            @id @default(uuid())
  type        TransactionType
  amount      Decimal           @db.Decimal(10, 2)
  description String
  date        DateTime          @default(now())
  status      TransactionStatus @default(PENDING)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id])

  // 👇 NUEVO: Relación para que el cobro sepa a qué suscripción pertenece
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 📊 MÓDULO REPORTES
model Report {
  id          String   @id @default(uuid())
  title       String
  type        String
  dataUrl     String?
  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())
}

// ====================================================
// 🧾 MÓDULO FACTURACIÓN ELECTRÓNICA (CFDI 4.0)
// ====================================================

model FacEmisor {
  id               String   @id @default(uuid())
  rfc              String   @unique @db.VarChar(13)
  razonSocial      String   @db.VarChar(254)
  nombreComercial  String?  @db.VarChar(254)
  regimenFiscal    String   @db.VarChar(3)
  cp               String   @db.VarChar(5)
  esZonaFronteriza Boolean  @default(false)
  calle            String?
  colonia          String?
  municipio        String?
  estado           String?
  pais             String   @default("MEX")
  telefono         String?
  logoBase64       String?  @db.Text
  eslogan          String?
  emailEnvio       String?
  serieDefault     String   @default("A") // Control de serie
  folioActual      Int      @default(0) // Control automático de folios (empieza en 0 para que el primer folio sea 1)
  activo           Boolean  @default(true)
  createdAt        DateTime @default(now())

  certificados FacCSD[]
  receptores   FacReceptor[]
  productos    FacProducto[]
  cfdis        FacCFDI[]
}

model FacCSD {
  id            String    @id @default(uuid())
  emisorId      String
  emisor        FacEmisor @relation(fields: [emisorId], references: [id])
  cerBase64     String    @db.Text
  keyBase64     String    @db.Text
  password      String
  noCertificado String?
  vigencia      DateTime?
  activo        Boolean   @default(true)
  default       Boolean   @default(false)
  createdAt     DateTime  @default(now())
}

model FacReceptor {
  id            String    @id @default(uuid())
  emisorId      String // FK obligatoria para aislamiento por emisor
  emisor        FacEmisor @relation(fields: [emisorId], references: [id])
  rfc           String    @db.VarChar(13)
  razonSocial   String    @db.VarChar(254)
  cpFiscal      String    @db.VarChar(5)
  regimenFiscal String    @db.VarChar(3)
  email         String?
  pais          String    @default("MEX")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  cfdis         FacCFDI[]

  // Un emisor no puede tener dos veces al mismo cliente registrado
  @@unique([emisorId, rfc])
}

model FacProducto {
  id                String    @id @default(uuid())
  emisorId          String // FK obligatoria para aislamiento por emisor
  emisor            FacEmisor @relation(fields: [emisorId], references: [id])
  claveProdServ     String    @db.VarChar(8)
  claveUnidad       String    @db.VarChar(6)
  descripcionUnidad String    @db.VarChar(100)
  noIdentificacion  String?   @db.VarChar(100)
  descripcion       String    @db.VarChar(1000)
  valorUnitario     Decimal   @db.Decimal(18, 6) // 6 decimales para precisión en SAT
  objetoImpuesto    String    @db.VarChar(2)
  impuestos         Json
  activo            Boolean   @default(true)
  createdAt         DateTime  @default(now())
}

model FacCFDI {
  id         String      @id @default(uuid())
  emisorId   String
  emisor     FacEmisor   @relation(fields: [emisorId], references: [id])
  receptorId String
  receptor   FacReceptor @relation(fields: [receptorId], references: [id])

  tipoCFDI        String   @db.VarChar(1) // I, E, P, N, T
  serie           String?  @db.VarChar(25)
  folio           Int
  fecha           DateTime @default(now())
  usoCFDI         String   @db.VarChar(5)
  metodoPago      String?  @db.VarChar(3)
  formaPago       String?  @db.VarChar(2)
  moneda          String   @default("MXN")
  tipoCambio      Decimal  @default(1) @db.Decimal(10, 4)
  condicionesPago String?  @db.VarChar(1000)
  observaciones   String?  @db.VarChar(1000)
  exportacion     String   @default("01")

  conceptos Json

  subtotal                  Decimal @db.Decimal(18, 2)
  descuento                 Decimal @default(0) @db.Decimal(18, 2)
  totalImpuestosTrasladados Decimal @default(0) @db.Decimal(18, 2)
  totalImpuestosRetenidos   Decimal @default(0) @db.Decimal(18, 2)
  total                     Decimal @db.Decimal(18, 2)

  estado           String    @default("BORRADOR")
  satUuid          String?   @unique @db.VarChar(36)
  noCertificado    String?   @db.VarChar(20)
  noCertificadoSAT String?   @db.VarChar(20)
  fechaTimbrado    DateTime?
  selloCFDI        String?   @db.Text
  selloSAT         String?   @db.Text
  cadenaOriginal   String?   @db.Text
  xmlTimbrado      String?   @db.Text
  pdfGenerado      Boolean   @default(false)

  motivoCancelacion String? @db.VarChar(2)
  folioSustitucion  String? @db.VarChar(36)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones corregidas para evitar conflictos en Prisma
  pagosRecibidos FacComplementoPago[] @relation("FacturaRelacionada")
  pagosEmitidos  FacComplementoPago[] @relation("FacturaPago")
}

model FacComplementoPago {
  id                String  @id @default(uuid())
  cfdiRelacionadoId String // El ID de la Factura original (Ingreso)
  cfdiPagoId        String? // El ID del CFDI tipo Pago generado

  cfdiRelacionado FacCFDI  @relation("FacturaRelacionada", fields: [cfdiRelacionadoId], references: [id])
  cfdiPago        FacCFDI? @relation("FacturaPago", fields: [cfdiPagoId], references: [id])

  fechaPago        DateTime
  formaPago        String   @db.VarChar(2)
  moneda           String   @default("MXN")
  monto            Decimal  @db.Decimal(18, 2)
  numParcialidad   Int
  impSaldoAnt      Decimal  @db.Decimal(18, 2)
  impPagado        Decimal  @db.Decimal(18, 2)
  impSaldoInsoluto Decimal  @db.Decimal(18, 2)

  createdAt DateTime @default(now())
}
