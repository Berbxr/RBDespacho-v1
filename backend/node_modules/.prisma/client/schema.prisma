// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------
// ENUMS PARA INTEGRIDAD FINANCIERA Y FACTURACIÓN
// ----------------------------------------------------
enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionStatus {
  PENDING
  PAID
  CANCELLED
}

enum RecurrenceFrequency {
  MONTHLY
  ANNUAL
}

// NUEVO: Enum para el estado de las facturas (Borradores vs SAT)
enum InvoiceStatus {
  DRAFT // Borrador (No timbrada)
  TIMBRADA // Aprobada por el SAT
  CANCELLED // Cancelada en el SAT
}

// 👤 MÓDULO AUTH
model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// 📦 MÓDULO SERVICIOS Y CLIENTES
model Service {
  id           String                 @id @default(uuid())
  name         String                 @unique
  isActive     Boolean                @default(true)
  transactions FinancialTransaction[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
}

model Client {
  id                String                 @id @default(uuid())
  firstName         String
  lastName1         String
  lastName2         String?
  documentReminders DocumentReminder[]
  rfc               String                 @unique
  phone             String?
  email             String?
  isActive          Boolean                @default(true)
  transactions      FinancialTransaction[]
  subscriptions     Subscription[]
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
}

// ⏰ MÓDULO RECORDATORIOS
model DocumentReminder {
  id String @id @default(uuid())

  // Relación con el Cliente
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  documentType   String
  rfc            String?
  expirationDate DateTime
  notified7Days  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 🔄 MÓDULO SUSCRIPCIONES
model Subscription {
  id          String              @id @default(uuid())
  clientId    String
  client      Client              @relation(fields: [clientId], references: [id])
  serviceName String
  amount      Decimal             @db.Decimal(10, 2)
  frequency   RecurrenceFrequency
  startDate   DateTime
  nextBilling DateTime
  isActive    Boolean             @default(true)

  // 👇 NUEVO: Relación para que la suscripción sepa cuáles son sus recibos generados
  transactions FinancialTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 💰 MÓDULO FINANZAS
model FinancialTransaction {
  id          String            @id @default(uuid())
  type        TransactionType
  amount      Decimal           @db.Decimal(10, 2)
  description String
  date        DateTime          @default(now())
  status      TransactionStatus @default(PENDING)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id])

  // 👇 NUEVO: Relación para que el cobro sepa a qué suscripción pertenece
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 📊 MÓDULO REPORTES
model Report {
  id          String   @id @default(uuid())
  title       String
  type        String
  dataUrl     String?
  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())
}

// ====================================================
// 🧾 MÓDULO FACTURACIÓN ELECTRÓNICA (CFDI 4.0)
// ====================================================

model BillingEmisor {
  id            String            @id @default(uuid())
  rfc           String            @unique
  razonSocial   String
  regimenFiscal String
  codigoPostal  String
  email         String?
  // Relaciones: Aislamiento de datos por Emisor (Estilo inoWebs)
  receptores    BillingReceptor[]
  conceptos     BillingConcept[]
  invoices      Invoice[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model BillingReceptor {
  id             String        @id @default(uuid())
  emisorId       String
  emisor         BillingEmisor @relation(fields: [emisorId], references: [id], onDelete: Cascade)
  rfc            String
  razonSocial    String
  usoCfdiDefault String
  regimenFiscal  String
  codigoPostal   String
  email          String?
  invoices       Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Un emisor no puede tener el mismo RFC de cliente duplicado, pero diferentes emisores sí.
  @@unique([emisorId, rfc])
}

model BillingConcept {
  id                 String        @id @default(uuid())
  emisorId           String
  emisor             BillingEmisor @relation(fields: [emisorId], references: [id], onDelete: Cascade)
  claveProdServ      String
  noIdentificacion   String?
  descripcion        String
  claveUnidad        String
  valorUnitario      Decimal       @db.Decimal(10, 2)
  impuestoTrasladado Decimal       @db.Decimal(5, 4)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model Invoice {
  id              String          @id @default(uuid())
  emisorId        String
  emisor          BillingEmisor   @relation(fields: [emisorId], references: [id])
  receptorId      String
  receptor        BillingReceptor @relation(fields: [receptorId], references: [id])
  tipoComprobante String // 'I' (Ingreso), 'E' (Egreso), 'P' (Pago)
  metodoPago      String? // 'PUE' o 'PPD'
  formaPago       String?
  subtotal        Decimal         @db.Decimal(10, 2)
  total           Decimal         @db.Decimal(10, 2)

  // SOLUCIÓN BUG 2: Guardado de identificadores oficiales
  satUuid     String  @unique
  facturamaId String?
  folio       String?
  status      String  @default("TIMBRADA") // TIMBRADA, CANCELADA

  // Relación para Complementos de Pago
  complementosEmitidos PaymentComplement[] @relation("FacturaPagos")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// NUEVO: Modelo para Control de Complementos de Pago (REP)
model PaymentComplement {
  id              String   @id @default(uuid())
  invoiceOrigenId String // La factura tipo 'I' (PPD) original
  invoiceOrigen   Invoice  @relation("FacturaPagos", fields: [invoiceOrigenId], references: [id])
  cfdiPagoUuid    String   @unique // El UUID del recibo de pago timbrado
  montoPagado     Decimal  @db.Decimal(10, 2)
  parcialidad     Int      @default(1)
  saldoAnterior   Decimal  @db.Decimal(10, 2)
  saldoInsoluto   Decimal  @db.Decimal(10, 2)
  fechaPago       DateTime
  createdAt       DateTime @default(now())
}
